# Braindance environment variables
#
# Copy this file to `.env` and fill in real values:
#   cp .env.example .env
#
# Bun auto-loads `.env` at startup. Spawned MCP subprocesses inherit
# the parent process environment, so no per-server env passthrough is
# needed in config.yaml — these keys are read directly by our provider
# code and forwarded to MCP servers by inheritance.


# ─── LLM provider (OpenRouter) ───────────────────────────────────────
# Required for capability agents (discover, audit, strategy, writer).
# Create a key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=


# ─── Exa MCP server ──────────────────────────────────────────────────
# Required for the `web` discovery channel AND the URL seed handler
# (Exa's `contents` tool scrapes URLs into sources).
# Create a key at: https://dashboard.exa.ai/api-keys
EXA_API_KEY=


# ─── Optional overrides ──────────────────────────────────────────────
# Relocate registry.db + projects/ (e.g. to an external drive or a
# cloud-synced folder). Defaults to the OS-standard user data dir.
# BRAINDANCE_DATA_DIR=
